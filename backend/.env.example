# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Claude AI
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# Database
DATABASE_URL=sqlite:///./data/search_score_send.db
DATABASE_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# n8n
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_URL=http://localhost:5678/api/v1
N8N_API_KEY=your-n8n-api-key

# HITL
HITL_APPROVAL_TIMEOUT_MINUTES=60
HITL_FINAL_APPROVAL_TIMEOUT_HOURS=24
DEFAULT_REVIEWER_EMAIL=recruiter@company.com

# Email (for HITL notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@search-score-send.com

# Redis (for SSE and task queue)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-for-jwt-signing
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# GDPR
DATA_RETENTION_DAYS=180
ANONYMIZATION_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/api.log

# Search Platform APIs
LINKEDIN_API_KEY=your-linkedin-key
GITHUB_API_KEY=your-github-token
STACKOVERFLOW_API_KEY=your-stackoverflow-key

# Feature Flags
ENABLE_HITL=true
ENABLE_SSE_PROGRESS=true
ENABLE_AUDIT_LOGGING=true
